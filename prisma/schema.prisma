generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // Super Admin, Admin, Operador
  users User[]
}

model User {
  id         Int      @id @default(autoincrement())
  correo     String   @unique
  password   String
  documento  String   @unique
  nombre     String
  apellidos  String
  lastLogin  DateTime @default(now())
  isActive   Boolean  @default(true)
  roleId               Int
  role                 Role     @relation(fields: [roleId], references: [id])
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Lote {
  id                Int      @id @default(autoincrement())
  wo                String   // e.g. "5465511"
  numeroLote        String   // e.g. "L1"
  modelo            String?  // e.g. "CT-100 ES/KS"
  cantidadEstibas   Int      // Total estibas
  fechaIntervencion DateTime
  fechaProduccion   DateTime
  estibas           Estiba[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([wo, numeroLote]) // Un lote es único por WO y su número (ej. 5465511 - L1)
}

model Estiba {
  id           Int      @id @default(autoincrement())
  codigoBarras String   @unique // e.g. EST-XYZ987
  tipo         String   @default("GENERAL") // e.g. CHASIS, PLASTICO, MOTORES, TORNILERIA, TANQUES
  loteId       Int
  lote         Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)
  status       String   @default("STORED") // IN_TRANSIT, STORED, DISPATCHED
  ubicacion    Ubicacion?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Rack {
  id          Int         @id @default(autoincrement())
  nombre      String      @unique // e.g. "A01"
  columnas    Int         @default(1) // Cantidad de columnas (ancho)
  niveles     Int         @default(7) // Altura
  profundidad Int         @default(10) // LIFO depth
  isActive    Boolean     @default(true) // Puede desactivarse pero no borrarse/repetirse
  ubicaciones Ubicacion[]
  createdAt   DateTime    @default(now())
}

model Ubicacion {
  id          Int      @id @default(autoincrement())
  rackId      Int
  rack        Rack     @relation(fields: [rackId], references: [id], onDelete: Cascade)
  columna     Int      // 1 al N
  nivel       Int      // 1 al 7
  profundidad Int      // 1 al 10 (1 = frente, 10 = fondo LIFO)
  estibaId    Int?     @unique
  estiba      Estiba?  @relation(fields: [estibaId], references: [id], onDelete: SetNull)
  
  @@unique([rackId, columna, nivel, profundidad])
}
